# ─────────────────────────────────────────────
#  PO3/AMD 剥头皮机器人 配置模板（Bitget 专版）
#  复制为 .env 并填入真实值
# ─────────────────────────────────────────────

# ── Bitget API 凭证 ──
PO3_API_KEY=your_api_key_here
PO3_API_SECRET=your_api_secret_here
PO3_API_PASSPHRASE=your_api_passphrase_here   # Bitget 必填

# ── 网络环境 ──
PO3_TESTNET=true              # true=测试网, false=实盘

# ── 交易标的（逗号分隔多币种）──
PO3_SYMBOLS=BTC/USDT:USDT,ETH/USDT:USDT,SOL/USDT:USDT

# ── 杠杆与保证金 ──
PO3_LEVERAGE=30               # 建议 25~40
PO3_MARGIN_MODE=isolated      # isolated | cross

# ── 风控 ──
PO3_RISK_PER_TRADE=0.01       # 每笔风险 1% 账户净值
PO3_MAX_DAILY_TRADES=10       # 每日最多交易次数 (8~12)
PO3_MAX_DAILY_LOSS=0.06       # 每日最大亏损 6%
PO3_MAX_CONSECUTIVE_LOSSES=3  # 连续亏损熔断次数
PO3_CONSECUTIVE_LOSS_COOLDOWN=7200  # 熔断冷却秒数（默认2小时）
PO3_MAX_HOLDING_TIME=3600     # 最大持仓秒数（默认1小时）

# ── 手续费 & 滑点 ──
PO3_MAKER_FEE=0.0002          # Maker 手续费 0.02%
PO3_TAKER_FEE=0.0005          # Taker 手续费 0.05%
PO3_SLIPPAGE_BPS=2            # 预估滑点（基点）

# ── 止盈止损 RR ──
PO3_TP1_RR=2.2                # 第一止盈 RR 倍数
PO3_TP2_RR=3.0                # 第二止盈目标（trailing stop 跟踪）
PO3_TP1_CLOSE_PCT=0.5         # 第一止盈平仓比例 50%
PO3_SL_ATR_BUFFER=0.2         # SL 在 manipulation 极值外侧 ATR*0.2

# ── 波动率过滤 ──
PO3_VOL_FILTER=true           # 是否启用波动率过滤
PO3_VOL_ATR_THRESHOLD=0.05    # 日线 ATR% 阈值（超过则暂停）
PO3_VOL_LOOKBACK=14           # 日线 ATR 计算周期

# ── PO3 检测参数 ──
PO3_ACC_BARS=10               # 累积阶段最小 K 线数量
PO3_ACC_ATR_MULT=1.5          # 累积区间高度 < ATR * 此值才算累积
PO3_MANIP_ATR_MULT=0.5        # 假突破需超出 ATR * 此值
PO3_MANIP_MAX_AGE_BARS=8      # Manipulation 有效窗口（15m K 线根数，超时放弃）

# ── Trailing Stop ──
PO3_TRAILING_ATR_MULT=1.5     # Trailing stop 距离 = ATR * 此值

# ── 事件循环间隔 ──
PO3_POLL_1M=5                 # Trailing tick 间隔（秒）

# ── 日志 ──
LOG_LEVEL=INFO
PO3_QUIET=false               # 精简模式（只输出信号和交易）

# ── 紧急平仓 ──
PO3_EMERGENCY_DELAY=10        # 紧急平仓延迟秒数（可取消）

# ── API 服务 ──
PO3_API_HOST=0.0.0.0
PO3_API_PORT=8000
